# Public API URL (Railway or local). No trailing slash.
NEXT_PUBLIC_PULSEFILL_API_URL=http://127.0.0.1:3001

# Staff sign-in (Supabase Auth — same project as the API uses for JWT verification).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Optional: dev-only fallback bearer (prefer Supabase sign-in or legacy paste on /login).
# NEXT_PUBLIC_DEV_STAFF_ACCESS_TOKEN=

# Optional: log Supabase Realtime postgres_changes payloads to the browser console (remove after verifying).
# NEXT_PUBLIC_REALTIME_DEBUG=true

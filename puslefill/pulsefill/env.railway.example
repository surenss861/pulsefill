# Copy sections into Railway service variables (do not commit real secrets).
# Supabase project: https://supabase.com/dashboard
#
# Where variables live:
# - REDIS_URL, SUPABASE_SERVICE_ROLE_KEY, STRIPE_SECRET_KEY → Railway API (and worker), NOT Vercel,
#   unless a Vercel *server* route truly needs them (dashboard-only frontends should not).
# - If any Redis URL/password was ever exposed (chat, screenshot), rotate it in Railway and update REDIS_URL.

# --- Shared: api + worker ---
NODE_ENV=production
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- BullMQ + API rate limits (Railway Redis plugin: use the TCP URL they provide) ---
# When set on the API, @fastify/rate-limit uses Redis so limits are shared across scaled instances.
REDIS_URL=

# --- API service only (optional; queue still works if Redis unset but jobs won’t enqueue) ---
PORT=3001
LOG_LEVEL=info
# Set to 1/true to disable @fastify/rate-limit (e.g. emergency debugging only; keep enabled in production).
# RATE_LIMIT_DISABLED=0
# Comma-separated exact browser origins (no path, optional trailing slash stripped at parse).
# Required in production or the dashboard on Vercel will get no Access-Control-Allow-Origin.
API_CORS_ORIGINS=https://pulsefill.vercel.app,http://localhost:3000

# --- API: Stripe (optional for pilot) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# ENABLE_BILLING_ROUTES=0
# ENABLE_STRIPE_WEBHOOK_ROUTES=0

# --- Worker: APNs (optional until real push) ---
# APNS_KEY_ID=
# APNS_TEAM_ID=
# APNS_BUNDLE_ID=com.pulsefill.customer
# APNS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# APNS_ENVIRONMENT=production

# --- Dashboard / Next (Vercel or static host; not Railway secrets) ---
# NEXT_PUBLIC_PULSEFILL_API_URL=https://YOUR_API.up.railway.app

# --- iOS / Simulator (Xcode scheme environment; not Railway) ---
# PULSEFILL_TIER=staging
# PULSEFILL_API_BASE_URL=https://YOUR_API.up.railway.app
# PULSEFILL_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# PULSEFILL_SUPABASE_ANON_KEY=
